\newcommand{\siglalista}[2]{\newacronym{#1}{#1}{#2}} 

\newglossary{simbolos}{simbolos}{sbl}{simbolos}

\newcommand{\simbololista}[3]{\newglossaryentry{#1}{%
	type=simbolos, 
	name=#2, 
	description=#3}}

\newglossary{glossario}{glossario}{glo}{glossario}		
